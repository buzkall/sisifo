{
    "name": "arzcode/sisifo",
    "description": "Sisifo — autonomous email/inbox watcher and summarizer as a Filament v5 plugin.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "mailbox",
        "ai",
        "automation"
    ],
    "authors": [
        {
            "name": "Arzcode"
        }
    ],
    "require": {
        "php": "^8.3",
        "beyondcode/laravel-mailbox": "^6.0",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-settings-plugin": "^5.0",
        "laravel/framework": "^13.0",
        "league/html-to-markdown": "^5.1",
        "prism-php/prism": "^0.99.2",
        "spatie/laravel-settings": "^3.0",
        "webklex/laravel-imap": "^6.2"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.2",
        "nunomaduro/collision": "^8.1",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Arzcode\\Sisifo\\": "src/",
            "Arzcode\\Sisifo\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arzcode\\Sisifo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --compact",
        "format": "vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arzcode\\Sisifo\\SisifoServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
